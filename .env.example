# ============================================
# WhyNot Chatbot — Konfigurasi
# ============================================
# Salin file ini ke .env dan isi dengan nilai Anda:
#   cp .env.example .env

# === Konfigurasi API ===

# Endpoint API (Kompatibel dengan OpenAI)
# Contoh:
#   OpenAI:      https://api.openai.com/v1
#   Anthropic:   https://api.anthropic.com/v1
#   OpenRouter:  https://openrouter.ai/api/v1
#   Local LLM:   http://localhost:1234/v1
API_ENDPOINT=https://api.openai.com/v1

# Nama model
# Contoh: gpt-4o, claude-sonnet-4-20250514, meta-llama/llama-3-70b-instruct
MODEL=gpt-4o

# API key Anda
API_KEY=sk-your-api-key-here


# === Prompt Kustom (Opsional) ===
# Hilangkan komentar pada baris di bawah ini untuk mengganti prompt sistem bawaan.
# Batasan keamanan akan SELALU disuntikkan apa pun yang terjadi.
# CUSTOM_PROMPT=Prompt sistem kustom Anda di sini...

# === Server ===

# Port untuk menjalankan server
PORT=3000

# Ukuran maksimal unggah file dalam MB
MAX_FILE_SIZE=10
